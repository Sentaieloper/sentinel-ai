# Sentinel AI — Environment Variables

# Solana RPC endpoint
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# Sentinel AI program ID (deployed to devnet)
PROGRAM_ID=

# Path to crank keypair JSON file
CRANK_KEYPAIR_PATH=./crank-keypair.json

# Helius API key (for enhanced RPC)
HELIUS_API_KEY=

# Birdeye API key (for token prices)
BIRDEYE_API_KEY=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitoring interval in seconds
MONITOR_INTERVAL_SECONDS=30
